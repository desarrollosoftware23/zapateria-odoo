<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Heredar vista de lista para agregar campo precio_oferta -->
    <record id="view_zapato_list_descuento" model="ir.ui.view">
        <field name="name">zapatos.zapato.list.descuento</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapato_list"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='precio']" position="after">
                <field name="precio_oferta"/>
            </xpath>
        </field>
    </record>

    <!-- Heredar vista de formulario para agregar campo precio_oferta -->
    <record id="view_zapato_form_descuento" model="ir.ui.view">
        <field name="name">zapatos.zapato.form.descuento</field>
        <field name="model">zapatos.zapato</field>
        <field name="inherit_id" ref="zapatos.view_zapato_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='precio']" position="after">
                <field name="precio_oferta"/>
            </xpath>
        </field>
    </record>
</odoo>
