<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_zapato_form_inherit_temporadas" model="ir.ui.view">
            <field name="name">zapatos.zapato.form.inherit.temporadas</field>
            <field name="model">zapatos.zapato</field>
            <field name="inherit_id" ref="zapatos.view_zapato_form"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='precio']" position="after">
                    <field name="temporada"/>
                </xpath>
            </field>
        </record>

        <record id="view_zapato_list_inherit_temporadas" model="ir.ui.view">
            <field name="name">zapatos.zapato.list.inherit.temporadas</field>
            <field name="model">zapatos.zapato</field>
            <field name="inherit_id" ref="zapatos.view_zapato_list"/>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='precio']" position="after">
                    <field name="temporada"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>