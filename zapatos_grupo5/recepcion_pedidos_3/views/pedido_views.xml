<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pedido_form" model="ir.ui.view">
        <field name="name">pedido.pedido.form</field>
        <field name="model">pedido.pedido</field>
        <field name="arch" type="xml">
            <form string="Pedido">
                <header>
                    <field name="estado" widget="statusbar"
                           statusbar_visible="pendiente,recibido"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="zapato_id"/>
                            <field name="proveedor"/>
                        </group>
                        <group>
                            <field name="fecha_pedido"/>
                            <field name="cantidad_solicitada"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_pedido_tree" model="ir.ui.view">
        <field name="name">pedido.pedido.tree</field>
        <field name="model">pedido.pedido</field>
        <field name="arch" type="xml">
            <list string="Pedidos">
                <field name="name"/>
                <field name="zapato_id"/>
                <field name="proveedor"/>
                <field name="fecha_pedido"/>
                <field name="cantidad_solicitada"/>
                <field name="estado"
                       decoration-warning="estado == 'pendiente'"
                       decoration-success="estado == 'recibido'"
                       widget="badge"/>
            </list>
        </field>
    </record>

    <record id="action_pedido" model="ir.actions.act_window">
        <field name="name">Pedidos</field>
        <field name="res_model">pedido.pedido</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
