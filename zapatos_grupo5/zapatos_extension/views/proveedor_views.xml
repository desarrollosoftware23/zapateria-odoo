<odoo>

    <record id="view_proveedor_tree" model="ir.ui.view">
        <field name="name">zapatos.proveedor.tree</field>
        <field name="model">zapatos.proveedor</field>
        <field name="arch" type="xml">
            <list>
                <field name="proveedor_id"/>
                <field name="razon_social"/>
                <field name="ruc"/>
                <field name="tipo_proveedor"/>
                <field name="telefono"/>
                <field name="correo"/>
                <field name="estado"/>
            </list>
        </field>
    </record>

    <record id="view_proveedor_form" model="ir.ui.view">
        <field name="name">zapatos.proveedor.form</field>
        <field name="model">zapatos.proveedor</field>
        <field name="arch" type="xml">
            <form string="Proveedor">
                <sheet>

                    <group>
                        <field name="imagen"
                               widget="image"
                               class="oe_avatar"/>
                    </group>

                    <group string="Información General">
                        <field name="proveedor_id" readonly="1"/>
                        <field name="razon_social"/>
                        <field name="ruc"/>
                        <field name="tipo_proveedor"/>
                        <field name="estado"/>
                    </group>

                    <group string="Información de Contacto">
                        <field name="nombre_contacto"/>
                        <field name="telefono"/>
                        <field name="correo"/>
                        <field name="pais"/>
                        <field name="ciudad"/>
                        <field name="direccion"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <record id="action_proveedores" model="ir.actions.act_window">
        <field name="name">Proveedores</field>
        <field name="res_model">zapatos.proveedor</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menú -->
    <menuitem
        id="menu_proveedores"
        name="Proveedores"
        parent="zapatos.menu_zapatos_root"
        action="action_proveedores"
        sequence="20"/>

</odoo>