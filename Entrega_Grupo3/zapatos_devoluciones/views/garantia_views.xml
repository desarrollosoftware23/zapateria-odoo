
<odoo>


    <record id="view_garantia_list" model="ir.ui.view">
        <field name="name">zapateria.garantia.list</field>
        <field name="model">zapateria.garantia</field>

        <field name="arch" type="xml">
            <list>
                <field name="codigo"/>
                <field name="fecha_inicio"/>
                <field name="fecha_fin"/>
                <field name="estado"/>
                <field name="zapato_id"/>
            </list>
        </field>
    </record>


    <record id="view_garantia_form" model="ir.ui.view">
        <field name="name">zapateria.garantia.form</field>
        <field name="model">zapateria.garantia</field>

        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="codigo"/>
                        <field name="fecha_inicio"/>
                        <field name="fecha_fin"/>
                        <field name="descripcion"/>
                        <field name="estado"/>
                        <field name="zapato_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_garantia" model="ir.actions.act_window">
        <field name="name">Garantías</field>
        <field name="res_model">zapateria.garantia</field>
        <field name="view_mode">list,form</field>
    </record>


    <menuitem
        id="menu_garantias"
        name="Garantías"
        parent="zapatos.menu_zapatos_root"
        action="action_garantia"
        sequence="30"/>

</odoo>