
<odoo>

    <record id="view_devolucion_list" model="ir.ui.view">
        <field name="name">zapateria.devolucion.list</field>
        <field name="model">zapateria.devolucion</field>

        <field name="arch" type="xml">
            <list>
                <field name="codigo"/>
                <field name="fecha"/>
                <field name="estado"/>
                <field name="zapato_id"/>
            </list>
        </field>
    </record>

    <record id="view_devolucion_form" model="ir.ui.view">
        <field name="name">zapateria.devolucion.form</field>
        <field name="model">zapateria.devolucion</field>

        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="codigo"/>
                        <field name="fecha"/>
                        <field name="motivo"/>
                        <field name="estado"/>
                        <field name="zapato_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="action_devolucion" model="ir.actions.act_window">
        <field name="name">Devoluciones</field>
        <field name="res_model">zapateria.devolucion</field>
        <field name="view_mode">list,form</field>
    </record>


    <menuitem
        id="menu_devoluciones"
        name="Devoluciones"
        parent="zapatos.menu_zapatos_root"
        action="action_devolucion"
        sequence="20"/>
</odoo>