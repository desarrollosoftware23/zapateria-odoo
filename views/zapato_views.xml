<odoo>
    <record id="view_zapato_search" model="ir.ui.view">
        <field name="name">zapatos.zapato.search</field>
        <field name="model">zapatos.zapato</field>
        <field name="arch" type="xml">
            <search string="Buscar Zapatos">
                <field name="name" string="Nombre"/>

                <filter name="talla_38" string="Talla_38" domain="[('talla', '=', 38)]"/>
                <filter name="talla_39" string="Talla_39" domain="[('talla', '=', 39)]"/>
                <filter name="talla_40" string="Talla_40" domain="[('talla', '=', 40)]"/>
                <filter name="talla_41" string="Talla_41" domain="[('talla', '=', 41)]"/>

                <separator/>

                <filter name="marca_nike" string="Nike" domain="[('talla', '=', Nike)]"/>
                <filter name="marca_adidas" string="Adidas" domain="[('talla', '=', Adidas)]"/>
                <filter name="marca_puma" string="Puma" domain="[('talla', '=', Puma)]"/>
            
                <separator/>

                <group expand="0" string="Agrupar por">
                    <filter name="group_categoria" string="Categoria" context="{'group_by': 'categoria_id'}"/>
                </group>
            
            </search>
        </field>
    </record>

    <record id="view_zapato_list" model="ir.ui.view">
        <field name="name">zapatos.zapato.list</field>
        <field name="model">zapatos.zapato</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="talla"/>
                <field name="precio"/>
                <field name="stock"/>
                <field name="activo"/>
            </list>
        </field>
    </record>

    <record id="view_zapato_form" model="ir.ui.view">
        <field name="name">zapatos.zapato.form</field>
        <field name="model">zapatos.zapato</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="talla"/>
                        <field name="precio"/>
                        <field name="stock"/>
                        <field name="activo"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <menuitem id="menu_zapatos_root" name="Zapatos" sequence="10"/>

    <menuitem id="menu_zapatos_zapatos"
              name="Registrar Zapatos"
              parent="menu_zapatos_root"
              action="action_zapato"
              sequence="10"/>
</odoo>